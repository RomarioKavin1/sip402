{
  "name": "@sip402/core",
  "version": "0.1.0",
  "description": "sip402 core — chain config, sip accounting, settlement rail (DirectRedeem/1Shot relayer), and ERC-7710 redemption primitives.",
  "license": "MIT",
  "author": "Romario Kavin",
  "homepage": "https://github.com/RomarioKavin1/sip402#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RomarioKavin1/sip402.git",
    "directory": "packages/core"
  },
  "keywords": [
    "x402",
    "batch-settlement",
    "erc-7710",
    "erc-7715",
    "eip-7702",
    "metamask",
    "smart-accounts",
    "ai-agents",
    "micropayments",
    "usdc",
    "base",
    "1shot"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "rail-proof": "tsx scripts/rail-proof.ts",
    "oneshot-mainnet-proof": "SIP_NETWORK=base tsx scripts/oneshot-mainnet-proof.ts"
  },
  "dependencies": {
    "@metamask/smart-accounts-kit": "1.6.0",
    "dotenv": "^17.4.2",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "vitest": "^2.1.0"
  }
}

# ── sip402 demo backend ───────────────────────────────────────────────────────
# The demo signs and submits REAL transactions, so it needs a funded key + RPC.

# Funded owner key. On Base Sepolia (testnet) this pays gas to fund the session
# and seller. Use a throwaway key — never a key holding real funds.
PRIVATE_KEY=0xYOUR_TESTNET_PRIVATE_KEY

# Network: "base-sepolia" (testnet, the live MetaMask demo) or "base" (mainnet).
SIP_NETWORK=base-sepolia

# RPC endpoint. The public default works; override if you get rate-limited.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ── mainnet only (leave unset for the testnet demo) ──────────────────────────
# BASE_RPC_URL=https://mainnet.base.org
# ONESHOT_RELAYER_URL=
# VENICE_API_URL=

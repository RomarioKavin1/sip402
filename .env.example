# Funded Base wallet private key (testnet today, mainnet tomorrow). Real key lives in .env (gitignored).
PRIVATE_KEY=0x
# Network toggle: "base-sepolia" (testnet, today) or "base" (mainnet, tomorrow)
SIP_NETWORK=base-sepolia
# RPC URLs (public defaults work; override if rate-limited)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_RPC_URL=https://mainnet.base.org
# 1Shot relayer (mainnet only)
ONESHOT_RELAYER_URL=https://relayer.1shotapi.com/relayers
# Venice (mainnet only; no API key needed for x402)
VENICE_API_URL=https://api.venice.ai
# Public base URL for 1Shot webhooks (e.g. an ngrok URL); optional, polling is the fallback
SIP_WEBHOOK_BASE_URL=
# npm publish token (already in .env)
NPM_TOKEN=
